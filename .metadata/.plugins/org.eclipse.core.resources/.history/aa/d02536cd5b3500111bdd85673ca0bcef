package tp2;

public class ParcialArboles {
	private BinaryTree<Integer> arbol;
	
	public boolean isLeftTree(int num) {
		if (this.arbol != null && !this.arbol.isEmpty()) {
			//Buscamos el nodo que contenga NUM
			BinaryTree<Integer> subRaiz = busqueda(this.arbol, num);
			//Si no se encontro el nodo, retornamos falso
			if (subRaiz == null) return false;
			
			// Calculamos los valores para izquierda y derecha
	        int cantIzq = -1; //inicializamos en -1
	        int cantDer = -1; //inicializamos en -1
	        
	        if (subRaiz.hasLeftChild()) cantIzq = contarUnicos(subRaiz.getLeftChild());//Si tiene hijo izquierdo, tenemos un hijo que procesar
	        if (subRaiz.hasRightChild()) cantDer= contarUnicos(subRaiz.getRightChild()); //Si tiene hijo derecho, tenemos un hijo que procesar
	        
	        // Devolvemos true solo si la izquierda es estrictamente mayor
	        return cantIzq > cantDer;
		} 
		return false; //Si está vacio el árbol
	}
	
	private BinaryTree<Integer> busqueda(BinaryTree<Integer> a, int num) {
		if (a.getData() == num) {
			return a;
		}
		BinaryTree<Integer> res = null; //Nodo a devolver
		
		if (a.hasLeftChild()) res = busqueda(a.getLeftChild(), num);
		//Para no pisar el valor quizás ya encontrado por izquierda, condicionamos que res sea igual a null
		if (res == null && a.hasRightChild()) res = busqueda(a.getRightChild(), num);
		
		return res; //No existe NUM en el árbol
		
	}
	
	private int contarUnicos(BinaryTree<Integer> a) {
		int total=0;
		if (a.hasLeftChild() ^ a.hasRightChild()) {
			total = 1;
		}
		
		// Sumamos lo que digan los hijos hacia abajo
        if (a.hasLeftChild()) total += contarUnicos(a.getLeftChild());
        if (a.hasRightChild()) total += contarUnicos(a.getRightChild());
        
		return total;
	}
}
