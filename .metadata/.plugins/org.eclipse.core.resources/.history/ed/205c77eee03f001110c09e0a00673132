package tp3;

import java.util.*;
public class RecorridosAG {

	public List<Integer> numerosImparesMayoresQuePreOrden (GeneralTree<Integer> a, Integer n){
		List<Integer> resultado = new LinkedList<Integer>();
		if (a!= null && !a.isEmpty()){
			preOrden(a, n, resultado);
		}
		
		return resultado;
	}
	
	private void preOrden(GeneralTree<Integer> a, Integer n, List<Integer> res){
		if (a.getData() % 2 != 0 && a.getData() > n) {
			res.add(a.getData());
		}
		
		if (a.hasChildren()) {
			List<GeneralTree<Integer>> hijos = a.getChildren();
			Iterator<GeneralTree<Integer>> iterador = hijos.iterator();
			while (iterador.hasNext()) {
				GeneralTree<Integer> hijo = iterador.next();
				preOrden(hijo, n, res);
			}
		}
		
	}
}
