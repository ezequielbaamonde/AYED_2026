	public static void generarLista(){
		//Hardcode de estudiantes
		Estudiante e1 = new Estudiante("23364/4", "Ezequiel", "Baamonde",  45782596, "ezequiel@gmail.com");
		Estudiante e2 = new Estudiante("23364/5", "Tomas", "Baamonde",  45782597, "tomas@gmail.com");
		Estudiante e3 = new Estudiante("23364/6", "Raul", "Baamonde",  45782598, "raul@gmail.com");
		//Creación de lista
		List<Estudiante> alumnos = new ArrayList<>();
		//Adición de alumnos
		alumnos.add(e1); alumnos.add(e2); alumnos.add(e3);
		//Copia de lista
		List<Estudiante> copia = new ArrayList<>(alumnos);
		//copia.addAll(alumnos);
		
		//Impresión lista original - Se podria modular
		for(Estudiante e: alumnos) {
			System.out.println(e.getNombre());
		}
		System.out.println("---");
		//Impresión lista copia - Se podria modular
		for(Estudiante ee: copia) {
			System.out.println(ee.getNombre());
		}
	}
	
	public static void main(String[] args) {
		List<Integer> numeros = new ArrayList<>();
		Scanner s = new Scanner(System.in);
